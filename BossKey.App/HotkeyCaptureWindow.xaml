<Window x:Class="BossKey.App.HotkeyCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460"
        Height="230"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF5F5F7"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp">
    <Window.Resources>
        <Style x:Key="NeutralButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="BorderBrush" Value="#FFE4E7EB" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="Foreground" Value="#25313D" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFF7F8FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource NeutralButtonStyle}">
            <Setter Property="Background" Value="#FF0A84FF" />
            <Setter Property="BorderBrush" Value="#FF0A84FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="10"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF0077EE" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF0077EE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="InstructionTextBlock"
                   FontSize="14"
                   Foreground="#30353B"
                   TextWrapping="Wrap" />

        <TextBlock x:Name="CurrentLabelTextBlock"
                   Grid.Row="1"
                   Margin="0,12,0,6"
                   FontSize="13"
                   Foreground="#69727A" />

        <Border Grid.Row="2"
                Padding="12,10"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#FFE2E5E9"
                Background="#FFFFFFFF">
            <TextBlock x:Name="HotkeyPreviewTextBlock"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Foreground="#1F2933" />
        </Border>

        <StackPanel Grid.Row="4"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="ClearButton"
                    Width="100"
                    Height="40"
                    Margin="0,0,8,0"
                    Style="{StaticResource NeutralButtonStyle}"
                    Click="ClearButton_OnClick" />
            <Button x:Name="OkButton"
                    Width="100"
                    Height="40"
                    Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OkButton_OnClick"
                    />
            <Button x:Name="CancelButton"
                    Width="100"
                    Height="40"
                    Style="{StaticResource NeutralButtonStyle}"
                    Click="CancelButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
